{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/auth/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ]
      },
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": { "Path": "/catalog/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/catalog" } ]
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "Match": { "Path": "/cart/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/cart" } ]
      },
      "catalog-grpc-route": {
        "ClusterId": "catalog-grpc-cluster",
        "Match": {
          "Path": "/catalog.ProductService/{**catch-all}",
          "Headers": [ { "Name": "Content-Type", "Values": [ "application/grpc" ], "Mode": "ExactHeader" } ]
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": { "authService": { "Address": "http://auth:8080/" } },
        "HttpRequest": { "Version": "1.1" }
      },
      "catalog-cluster": {
        "Destinations": { "catalogService": { "Address": "http://catalog:8080/" } },
        "HttpRequest": { "Version": "1.1" }
      },
      "cart-cluster": {
        "Destinations": { "cartService": { "Address": "http://cartservice:8080/" } },
        "HttpRequest": { "Version": "1.1" }
      },
      "catalog-grpc-cluster": {
        "Destinations": { "catalogGrpcService": { "Address": "http://catalog:8081/" } },
        "HttpRequest": {
          "Version": "2.0",
          "VersionPolicy": "RequestVersionExact"
        }
      }
    }
  },
  "AllowedHosts": "*"
}
